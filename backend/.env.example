# CreditSimulator Backend — Environment Variables
# ─────────────────────────────────────────────────
# Copy this file to .env for local development.
# NEVER commit .env to git — it may contain secrets.
# In production, set these in Render's Environment Variables panel.

# Model artifact paths (optional — defaults to backend/model/)
# Override to point to external storage in production.
# MODEL_PATH=/path/to/custom/model.pkl
# MEDIANS_PATH=/path/to/custom/train_medians.json
# META_PATH=/path/to/custom/model_metadata.json

# Rate limiting (default: 30/minute per IP)
# Tighten in production, e.g. 10/minute
# RATE_LIMIT=30/minute

# Logging level (default: INFO)
# Use DEBUG locally for verbose output
# LOG_LEVEL=INFO

# CORS allowed origins (default: * — open for demo)
# Restrict in production to trusted origins
# CORS_ORIGINS=["https://myapp.com"]
